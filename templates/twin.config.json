{
  "name": "twin",
  "system": "twin",
  "engine": "claude-code",
  "schedule": {
    "nightly": "02:30  (ingest + conditional tidy + sync; once/day, catches up on wake/login)",
    "weekly": "Sun 03:00  (ingest + lint + research + tidy + sync; once/ISO-week, same catch-up)"
  },
  "models": { "smart": "account-default", "cheap": "haiku" },
  "budget": {
    "research_gaps_per_week_target": 3,
    "research_cap_is_soft": true,
    "nightly_skips_when_unchanged": true
  },
  "domains": ["projects", "learning", "personal", "concepts", "people"],
  "capture": {
    "from_projects": "opt-in",
    "from_chats": true,
    "ask_when_new_and_important": true
  },
  "calendar": {
    "read": "apple-eventkit (all accounts), google-calendar MCP fallback",
    "write_account": "your-account-label",
    "write_calendar": "Your calendar name (e.g. Day Plan)",
    "write_calendar_id": "your-google-calendar-id@group.calendar.google.com"
  }
}

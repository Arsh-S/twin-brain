#!/usr/bin/env bash
# twin - personal second-brain CLI (Karpathy LLM-wiki pattern, Claude Code engine)
# Runs entirely on the logged-in Claude Code (Max subscription). No API tokens.
set -euo pipefail

# --- resolve TWIN_DIR (follow symlink to the real script, fall back to ~/twin) ---
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"; [[ "$src" != /* ]] && src="$dir/$src"
done
SELF="$(cd -P "$(dirname "$src")" && pwd)"
TWIN_DIR="${TWIN_DIR:-$(cd "$SELF/.." && pwd)}"
[ -d "$TWIN_DIR/wiki" ] || TWIN_DIR="$HOME/twin"
RAW="$TWIN_DIR/raw-sources"
INBOX="$RAW/inbox"
WIKI="$TWIN_DIR/wiki"
SKILLS="$TWIN_DIR/skills"
CONFIG="$TWIN_DIR/config"
REPORTS="$TWIN_DIR/reports"
LOG="$TWIN_DIR/log.md"
REGISTRY="$CONFIG/projects.json"

CLAUDE_BIN="${CLAUDE_BIN:-claude}"
AGENT_TOOLS="Bash,Read,Write,Edit,Glob,Grep"
RESEARCH_TOOLS="Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch"
AGENDA_TOOLS="Bash,Read,Write,Edit,Glob,Grep,mcp__google-calendar__list-events,mcp__google-calendar__list-calendars,mcp__google-calendar__get-current-time,mcp__google-calendar__create-event"
SCOUT_TOOLS="Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch"   # discovery scout: web + local, no MCP calendar writes
CHEAP_MODEL="${TWIN_CHEAP_MODEL:-haiku}"   # mechanical work runs on a cheap model to save quota
RESEARCH_TARGET="${TWIN_RESEARCH_TARGET:-${TWIN_RESEARCH_CAP:-3}}"  # soft target for web-research gaps per run (may be exceeded for high-value gaps)
REMINDER_LIST="${TWIN_REMINDER_LIST:-Reminders}"   # Apple Reminders list to write into

ts()      { date "+%Y-%m-%d %H:%M:%S"; }
day()     { date "+%Y-%m-%d"; }
stamp()   { date "+%Y-%m-%d-%H%M%S"; }
rnd()     { printf "%04x" $((RANDOM % 65536)); }
logline() { printf '\n## [%s] %s\n' "$(ts)" "$1" >> "$LOG"; }
die()     { echo "twin: $*" >&2; exit 1; }

# run a Claude Code agent headless, in the twin dir, using a skill prompt file
# run_agent <skill_file> [extra] [model] [tools]
run_agent() {
  local skill_file="$1"
  local extra="${2:-}"
  local model="${3:-}"
  local tools="${4:-$AGENT_TOOLS}"
  [ -f "$skill_file" ] || die "missing skill file: $skill_file"
  local prompt
  prompt="$(cat "$skill_file")"
  if [ -n "$extra" ]; then
    prompt="$prompt

---
# This run

$extra"
  fi
  local model_arg=()
  [ -n "$model" ] && model_arg=(--model "$model")
  ( cd "$TWIN_DIR" && "$CLAUDE_BIN" -p "$prompt" \
      --allowedTools "$tools" \
      ${model_arg[@]+"${model_arg[@]}"} \
      --permission-mode acceptEdits 2>&1 )
}

# is the wiki dirty (uncommitted changes under wiki/)? used as a delta guard.
wiki_dirty() { [ -n "$(cd "$TWIN_DIR" && git status --porcelain wiki/ 2>/dev/null)" ]; }

# --- registry helpers (python3, no jq dependency) ---
reg_get() { # path -> tracked|private|unknown
  python3 - "$REGISTRY" "$1" <<'PY'
import json,sys,os
reg,path=sys.argv[1],os.path.abspath(sys.argv[2])
try: d=json.load(open(reg))
except Exception: d={}
print(d.get(path,{}).get("status","unknown") if isinstance(d.get(path),dict) else d.get(path,"unknown"))
PY
}
reg_set() { # path status
  python3 - "$REGISTRY" "$1" "$2" <<'PY'
import json,sys,os
reg,path,status=sys.argv[1],os.path.abspath(sys.argv[2]),sys.argv[3]
try: d=json.load(open(reg))
except Exception: d={}
d[path]={"status":status,"name":os.path.basename(path),"updated":__import__("datetime").datetime.now().isoformat(timespec="seconds")}
json.dump(d,open(reg,"w"),indent=2)
print(f"{status}: {path}")
PY
}

cmd_capture() {
  local text="" source="cli" project="" mode="arg"
  while [ $# -gt 0 ]; do
    case "$1" in
      --file) mode="file"; text="$2"; shift 2;;
      --stdin) mode="stdin"; shift;;
      --source) source="$2"; shift 2;;
      --project) project="$2"; shift 2;;
      *) text="$1"; shift;;
    esac
  done
  local body
  case "$mode" in
    file)  body="$(cat "$text")"; source="${source:-file:$text}";;
    stdin) body="$(cat)";;
    *)     body="$text";;
  esac
  [ -n "$body" ] || die "nothing to capture"
  local f="$INBOX/$(stamp)-$(rnd).md"
  {
    echo "---"
    echo "captured: $(ts)"
    echo "source: $source"
    [ -n "$project" ] && echo "project: $project"
    echo "status: unprocessed"
    echo "---"
    echo
    echo "$body"
  } > "$f"
  logline "capture | source=$source${project:+ project=$project} -> ${f#$TWIN_DIR/}"
  echo "captured -> ${f#$TWIN_DIR/}"
}

cmd_ingest() {
  local pending
  pending="$( { find "$INBOX" -name '*.md' -type f; find "$RAW/chats" -name '*.md' -type f; } 2>/dev/null | sort || true)"
  local extra
  if [ "${1:-}" = "--all" ] || [ -z "${1:-}" ]; then
    if [ -z "$pending" ]; then echo "twin: nothing to ingest (inbox + chats empty)"; return 0; fi
    extra="Unprocessed sources in raw-sources/inbox/ and raw-sources/chats/ (a chat file has a
companion .transcript.jsonl; read it for the session content). Process each, then move it to
raw-sources/processed/ after summarizing:
$pending"
  else
    extra="Process this specific source: $1"
  fi
  logline "ingest started"
  run_agent "$SKILLS/ingest.md" "$extra"
  logline "ingest finished"
}

cmd_ask() {
  [ $# -gt 0 ] || die "usage: twin ask \"question\""
  run_agent "$SKILLS/ask.md" "Question: $*"
}

cmd_clip() { # fetch a web page as clean markdown (defuddle) into the inbox
  [ $# -gt 0 ] || die "usage: twin clip URL"
  local url="$1"
  command -v defuddle >/dev/null 2>&1 || die "defuddle not installed (npm i -g defuddle)"
  local title body f
  title="$(defuddle parse "$url" -p title 2>/dev/null || echo "$url")"
  body="$(defuddle parse "$url" --md 2>/dev/null)"
  [ -n "$body" ] || die "could not extract content from $url"
  f="$INBOX/$(stamp)-$(rnd).md"
  {
    echo "---"; echo "captured: $(ts)"; echo "source: web:$url"
    echo "title: $title"; echo "status: unprocessed"; echo "---"; echo
    echo "# $title"; echo; echo "$body"
  } > "$f"
  logline "clip | $title <- $url -> ${f#$TWIN_DIR/}"
  echo "clipped: $title -> ${f#$TWIN_DIR/}"
}

cmd_lint() {
  logline "lint started"
  run_agent "$SKILLS/lint.md" "Write findings to reports/lint-report.md. Auto-fix safe issues; only flag destructive ones."
  logline "lint finished"
}

cmd_tidy() { # cheap mechanical clean + sort (runs on the cheap model)
  logline "tidy started ($CHEAP_MODEL)"
  run_agent "$SKILLS/tidy.md" "Touch only what changed since the last commit (use git status/diff). Be fast and mechanical; no deep reasoning, no web." "$CHEAP_MODEL"
  logline "tidy finished"
}

cmd_research() { # soft-budgeted web-research gap-fill (smart model + web tools)
  local n="${1:-$RESEARCH_TARGET}"
  logline "research started (target $n, soft)"
  run_agent "$SKILLS/research.md" "Target ~$n highest-value gaps from reports/lint-report.md. This is a SOFT target, not a hard cap: you may exceed it for clearly high-value gaps (see the skill's Soft budget section), but don't run away or fill low-value gaps to use budget. Log each gap filled; if you went over the target, note why. If none worth filling, do nothing." "" "$RESEARCH_TOOLS"
  logline "research finished"
}

cmd_remind() { # Apple Reminders via EventKit (no app launch).
  #   twin remind "text" [--due "June 20, 2026 9:00 AM"] [--list NAME]
  #   twin remind done|edit|rm "match" [new title]
  [ "$(uname)" = "Darwin" ] || die "twin remind needs macOS (Apple Reminders)"
  command -v swift >/dev/null 2>&1 || die "twin remind needs swift (Xcode Command Line Tools)"
  local rem="$SELF/twin-rem.swift"
  case "${1:-}" in
    done)   shift; swift "$rem" done "${1:?match}"; logline "remind done | $1";;
    edit)   shift; swift "$rem" edit "${1:?match}" "${2:?new title}"; logline "remind edit | $1 -> $2";;
    rm|del|delete) shift; swift "$rem" delete "${1:?match}"; logline "remind rm | $1";;
    *)
      local text="" due="" list="$REMINDER_LIST"
      while [ $# -gt 0 ]; do
        case "$1" in
          --due)  due="$2"; shift 2;;
          --list) list="$2"; shift 2;;
          *) text="$1"; shift;;
        esac
      done
      [ -n "$text" ] || die "usage: twin remind \"text\" [--due \"June 20, 2026 9:00 AM\"] [--list NAME]"
      swift "$rem" add "$text" "$due" "$list" && logline "remind | $text${due:+ (due $due)}"
      ;;
  esac
}

cmd_calendar() { # events from ALL Apple Calendar accounts via EventKit (no app launch). arg: span days (default 1)
  [ "$(uname)" = "Darwin" ] || die "twin calendar needs macOS"
  command -v swift >/dev/null 2>&1 || die "twin calendar needs swift (Xcode Command Line Tools)"
  swift "$SELF/twin-cal.swift" "${1:-1}"
}

cmd_reminders() { # open reminders via EventKit (no app launch); fall back to osascript if not permitted
  [ "$(uname)" = "Darwin" ] || die "twin reminders needs macOS"
  if command -v swift >/dev/null 2>&1 && swift "$SELF/twin-rem.swift" list 2>/dev/null; then
    return 0
  fi
  osascript -e 'tell application "Reminders" to return name of (reminders whose completed is false)' 2>/dev/null | tr ',' '\n'
}

cmd_agenda() { # read Apple Calendar (all accounts) + Apple Reminders + priorities -> briefing in generated/
  logline "agenda started"
  run_agent "$SKILLS/agenda.md" "Today is $(date '+%Y-%m-%d (%A)'). Build today's agenda briefing now." "" "$AGENDA_TOOLS"
  logline "agenda finished"
}

cmd_scout() { # proactive outside-world discovery (web + smart model). mode: --deep (weekly) | --daily (morning peek)
  local mode="${1:---deep}"
  local extra
  case "$mode" in
    --daily) extra="Mode: --daily. Light, cheap peek — ONLY time-sensitive items (today/tonight or an imminent deadline). Use a stricter bar (merge-findings --bar 0.8 --cap 2). If nothing is urgent, surface nothing.";;
    *)       mode="--deep"; extra="Mode: --deep. Full weekly sweep across all interest categories and the user's locations, looking out ~1–4 weeks. Use merge-findings --bar 0.7 --cap 3.";;
  esac
  logline "scout started ($mode)"
  run_agent "$SKILLS/scout.md" "Today is $(date '+%Y-%m-%d (%A)'). Run the discovery scout now. $extra" "" "$SCOUT_TOOLS"
  logline "scout finished ($mode)"
}

cmd_morning() { # daily 08:00 job: briefing + triage, light scout peek, write today.json, morning ping.
  # once-per-day guard mirrors nightly: launchd runs this at 08:00 AND at login (RunAtLoad), so an
  # 08:00 missed because the Mac was off is caught up on next login — never more than once per day.
  local force="" stamp="$TWIN_DIR/.state/morning.lastrun" today; today="$(day)"
  [ "${1:-}" = "--force" ] && force=1
  mkdir -p "$TWIN_DIR/.state"
  if [ -z "$force" ] && [ "$(cat "$stamp" 2>/dev/null)" = "$today" ]; then
    echo "twin: morning already ran today ($today), skipping (use --force to override)"
    logline "morning skipped (already ran $today)"
    return 0
  fi
  logline "morning run started"
  cmd_health ingest || true   # fresh physical-state data before the briefing coaches on it
  cmd_agenda || true
  cmd_scout --daily || true
  cmd_sync -m "twin: morning $(day)" || true
  echo "$today" > "$stamp"
  logline "morning run finished"
}

cmd_chat() { # ingest a session transcript (used by SessionEnd hook). arg: transcript path
  local tp="${1:-}"; local cwd="${2:-}"
  [ -f "$tp" ] || die "transcript not found: $tp"
  local f="$RAW/chats/$(stamp)-$(rnd).md"
  {
    echo "---"
    echo "captured: $(ts)"
    echo "source: chat-session"
    echo "cwd: $cwd"
    echo "transcript: $tp"
    echo "status: unprocessed"
    echo "---"
  } > "$f"
  cp "$tp" "${f%.md}.transcript.jsonl" 2>/dev/null || true
  logline "chat captured | cwd=$cwd -> ${f#$TWIN_DIR/}"
  echo "chat captured -> ${f#$TWIN_DIR/}"
}

cmd_track()   { reg_set "${1:-$PWD}" tracked; }
cmd_private() { reg_set "${1:-$PWD}" private; }
cmd_check()   { reg_get "${1:-$PWD}"; }
cmd_projects() { cat "$REGISTRY" 2>/dev/null || echo "{}"; }

cmd_search() {
  [ $# -gt 0 ] || die "usage: twin search \"query\""
  if command -v qmd >/dev/null 2>&1; then
    # ensure the wiki collection exists and is current, then hybrid (semantic) search.
    # qsearch needs an embedding model; if absent it falls back to BM25, then to grep.
    qmd collection list 2>/dev/null | grep -q 'twin-wiki' \
      || qmd collection add "$WIKI" -n twin-wiki >/dev/null 2>&1
    qmd update >/dev/null 2>&1
    # hybrid: query expansion + BM25/vector RRF fusion (skip the reranker, which over-filters small wikis)
    local hits; hits=$(qmd qsearch "$*" -c twin-wiki --no-rerank 2>/dev/null)
    if [ -n "$hits" ]; then printf '%s\n' "$hits"
    else qmd search "$*" -c twin-wiki 2>/dev/null || grep -rin --include='*.md' "$*" "$WIKI"; fi
  else
    grep -rin --include='*.md' "$*" "$WIKI" || echo "no matches (install qmd for semantic search)"
  fi
}

# secret scan before commit; returns nonzero if likely secret found.
# Only scans files git would actually COMMIT (respects .gitignore) so gitignored
# session transcripts don't false-positive.
secret_scan() {
  cd "$TWIN_DIR"
  local hits
  hits="$(git ls-files -co --exclude-standard -z 2>/dev/null \
    | xargs -0 grep -InE \
      '(sk-[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|AIza[0-9A-Za-z_-]{35})' \
      2>/dev/null || true)"
  if [ -n "$hits" ]; then
    echo "twin: POSSIBLE SECRETS DETECTED, aborting sync:" >&2
    echo "$hits" | head -20 >&2
    return 1
  fi
  return 0
}

cmd_sync() {
  local msg="twin: sync $(ts)"
  [ "${1:-}" = "-m" ] && { msg="$2"; }
  cd "$TWIN_DIR"
  secret_scan || die "fix secrets before syncing"
  git add -A
  if git diff --cached --quiet; then echo "twin: nothing to sync"; return 0; fi
  git commit -q -m "$msg"
  if git remote get-url origin >/dev/null 2>&1; then
    git push -q && echo "twin: pushed"
  else
    echo "twin: committed (no remote configured)"
  fi
}

cmd_nightly() { # cheap: ingest new, tidy ONLY if something changed, sync. near-zero on quiet days.
  # once-per-day guard: launchd runs this at midnight AND at login (RunAtLoad), so a midnight that
  # was missed because the Mac was powered off is caught up on next login — but it never runs more
  # than once per calendar day. (Sleep is handled by launchd itself: it fires on wake.)
  local force="" stamp="$TWIN_DIR/.state/nightly.lastrun" today; today="$(day)"
  [ "${1:-}" = "--force" ] && force=1
  mkdir -p "$TWIN_DIR/.state"
  if [ -z "$force" ] && [ "$(cat "$stamp" 2>/dev/null)" = "$today" ]; then
    echo "twin: nightly already ran today ($today), skipping (use --force to override)"
    logline "nightly skipped (already ran $today)"
    return 0
  fi
  logline "nightly run started"
  cmd_ingest --all || true
  cmd_health ingest || true
  if wiki_dirty; then
    cmd_tidy || true
  else
    echo "twin: no wiki changes tonight, skipping tidy (saves quota)"
    logline "nightly | nothing new, tidy skipped"
  fi
  cmd_sync -m "twin: nightly $(day)" || true
  echo "$today" > "$stamp"
  logline "nightly run finished"
}

cmd_weekly() { # deep: ingest, reconcile/health lint, soft-budgeted web research, sort, sync.
  # once-per-week guard, mirrors nightly: launchd runs this Sun 03:00 AND at login (RunAtLoad), so a
  # Sunday missed because the Mac was off is caught up on next login — but never runs more than once
  # per ISO week. (Asleep at the scheduled time is handled by launchd: it fires on wake.)
  local force="" stamp="$TWIN_DIR/.state/weekly.lastrun" thisweek; thisweek="$(date '+%G-W%V')"
  [ "${1:-}" = "--force" ] && force=1
  mkdir -p "$TWIN_DIR/.state"
  if [ -z "$force" ] && [ "$(cat "$stamp" 2>/dev/null)" = "$thisweek" ]; then
    echo "twin: weekly already ran this week ($thisweek), skipping (use --force to override)"
    logline "weekly skipped (already ran $thisweek)"
    return 0
  fi
  logline "weekly run started"
  cmd_ingest --all || true
  cmd_lint || true
  cmd_research "$RESEARCH_TARGET" || true
  cmd_scout --deep || true
  cmd_tidy || true
  cmd_sync -m "twin: weekly $(day)" || true
  echo "$thisweek" > "$stamp"
  logline "weekly run finished"
}

cmd_onboard() { # guided first run: setup + a live capture->ingest->ask demo
  local ok="  \033[32m✓\033[0m" bad="  \033[31m✗\033[0m" warn="  \033[33m!\033[0m"
  local C_B="\033[1;34m" C_DIM="\033[2m" C_0="\033[0m"
  printf "${C_B}Welcome to twin${C_0} — your second brain. Let's get you set up.\n\n"

  # 1. quick health: the essentials must be present
  echo "Checking your setup"
  local missing=0
  command -v claude  >/dev/null 2>&1 && printf "$ok claude CLI\n"   || { printf "$bad claude CLI not found — twin's engine (https://claude.com/product/claude-code)\n"; missing=1; }
  command -v git     >/dev/null 2>&1 && printf "$ok git\n"          || { printf "$bad git not found\n"; missing=1; }
  command -v python3 >/dev/null 2>&1 && printf "$ok python3\n"       || { printf "$bad python3 not found\n"; missing=1; }
  [ "$missing" = "0" ] || { echo; die "install the missing tools above, then re-run: twin onboard"; }
  printf "$ok vault at $TWIN_DIR\n\n"

  # non-interactive (piped/CI): run a smoke-test round-trip instead of prompting
  if [ ! -t 0 ]; then
    echo "No terminal detected — running a non-interactive smoke test."
    cmd_capture "twin onboarding smoke test: this fact was captured by 'twin onboard'." --source onboard >/dev/null
    cmd_ingest >/dev/null 2>&1 || true
    echo; echo "Asking the wiki to prove the round-trip worked:"
    cmd_ask "what was captured during onboarding?" || true
    echo; printf "${C_B}Smoke test done.${C_0} Run 'twin onboard' in a terminal for the guided setup, or 'twin doctor' to verify.\n"
    return 0
  fi

  # 2. seed profile.md — only if it is still the untouched template (never clobber real content)
  local profile="$WIKI/personal/profile.md"
  if [ -f "$profile" ] && grep -q "_(your name)_" "$profile" 2>/dev/null; then
    echo "A couple of questions so twin can personalize answers (Enter to skip any):"
    local name role project
    printf "  Your name? "        ; IFS= read -r name    || true
    printf "  What do you do? "    ; IFS= read -r role    || true
    printf "  Working on anything right now? "; IFS= read -r project || true
    if [ -n "$name$role$project" ]; then
      python3 - "$profile" "$name" "$role" "$project" "$(day)" <<'PY'
import sys
path,name,role,project,today=sys.argv[1:6]
name=name or "_(your name)_"; role=role or "_(what you do)_"
proj=project or "_(project — one line)_"
prio=project or "_(your #1 focus right now)_"
open(path,"w").write(f"""---
domain: personal
tags: [profile, identity, priorities]
pinned: true
---
# Profile

> The "who I am" context. ingest / ask / research read this FIRST so everything is personalized.
> Keep it short and current. Edit `## Priorities now` whenever they change.

## Identity
- **Name:** {name}
- **Location:** _(where you are)_
- **Role:** {role}

## Stack & how I work
- _(tools you use, e.g. Claude Code, Obsidian, your OS)_
- _(working preferences: tone, conventions, things to avoid)_

## Active projects
- {proj}

## Priorities now
<!-- EDIT THESE when they change — every workflow reads them. -->
1. {prio}
2. _(second)_
3. _(third)_

## Timeline
- ({today}) profile created via `twin onboard`
""")
PY
      printf "$ok saved to wiki/personal/profile.md\n"
    fi
    echo
  fi

  # 3. macOS Life-OS: trigger the EventKit permission prompt now so it's done before first use
  if [ "$(uname)" = "Darwin" ] && command -v swift >/dev/null 2>&1; then
    echo "Life-OS (calendar + reminders)"
    if swift "$SELF/twin-rem.swift" list >/dev/null 2>&1; then
      printf "$ok Reminders + Calendar access already granted\n"
    else
      printf "$warn macOS will now ask for Reminders/Calendar access — click Allow.\n"
      swift "$SELF/twin-rem.swift" list >/dev/null 2>&1 || true
      swift "$SELF/twin-cal.swift" 1   >/dev/null 2>&1 || true
      printf "    (if you missed it: System Settings > Privacy & Security > Reminders/Calendars)\n"
    fi
    echo
  fi

  # 4. live demo — costs a little quota (your Claude subscription), so confirm first
  printf "Want a 30-second live demo? twin will ${C_DIM}capture${C_0} a fact, ${C_DIM}ingest${C_0} it into\n"
  printf "the wiki, then ${C_DIM}ask${C_0} about it — proving the loop end-to-end. [Y/n] "
  local yn; IFS= read -r yn || true
  case "${yn:-y}" in
    [Nn]*) echo "Skipped the demo.";;
    *)
      local fact="${project:-I started using twin, a self-building second brain, today.}"
      echo; printf "${C_B}1/3 capture${C_0}\n"; cmd_capture "$fact" --source onboard
      printf "\n${C_B}2/3 ingest${C_0} ${C_DIM}(compiling into the wiki — this calls Claude)${C_0}\n"; cmd_ingest || true
      printf "\n${C_B}3/3 ask${C_0}\n"; cmd_ask "what did I just capture during onboarding?" || true
      ;;
  esac

  # 5. where to go next
  printf "\n${C_B}You're set up.${C_0} Next:\n"
  printf "  ${C_DIM}twin capture \"a thought\"${C_0}   drop anything into the inbox\n"
  printf "  ${C_DIM}twin ask \"...\"${C_0}             ask your brain, with citations\n"
  printf "  ${C_DIM}twin app${C_0}                    the web UI at http://localhost:5179\n"
  printf "  ${C_DIM}twin doctor${C_0}                 verify everything any time\n"
  printf "  Open ${C_DIM}$TWIN_DIR${C_0} in Obsidian (Open folder as vault) for the graph view.\n"
  printf "  Keep it private: push the vault to a ${C_B}private${C_0} git remote, never a public one.\n"
}

cmd_doctor() { # health check: deps, permissions, schedule, hooks, sync
  local ok="  \033[32m✓\033[0m" bad="  \033[31m✗\033[0m" warn="  \033[33m!\033[0m"
  echo "twin doctor @ $TWIN_DIR"
  echo
  echo "Core"
  command -v claude >/dev/null 2>&1 && printf "$ok claude CLI present ($(claude --version 2>/dev/null | head -1))\n" || printf "$bad claude CLI not found — twin's engine\n"
  command -v twin   >/dev/null 2>&1 && printf "$ok twin on PATH ($(command -v twin))\n" || printf "$warn twin not on PATH (add $TWIN_DIR/bin)\n"
  [ -d "$WIKI" ] && printf "$ok vault structure ($(find "$WIKI" -name '*.md' 2>/dev/null | wc -l | tr -d ' ') wiki pages)\n" || printf "$bad vault missing wiki/\n"
  command -v python3 >/dev/null 2>&1 && printf "$ok python3\n" || printf "$bad python3 missing (registry/status)\n"

  echo "Sync"
  if ( cd "$TWIN_DIR" && git rev-parse --is-inside-work-tree >/dev/null 2>&1 ); then
    if ( cd "$TWIN_DIR" && git remote get-url origin >/dev/null 2>&1 ); then
      printf "$ok git remote: $(cd "$TWIN_DIR" && git remote get-url origin)\n"
    else printf "$warn git repo but no remote (twin sync won't push)\n"; fi
    printf "    last commit: $(cd "$TWIN_DIR" && git log -1 --format='%cr — %s' 2>/dev/null | head -c 70)\n"
  else printf "$bad not a git repo (run: git init)\n"; fi

  echo "Automation"
  local jobs; jobs="$(launchctl list 2>/dev/null | grep -i twin | awk '{print $3}' | tr '\n' ' ')"
  [ -n "$jobs" ] && printf "$ok scheduled jobs loaded: $jobs\n" || printf "$warn no launchd jobs (nightly/weekly/morning won't auto-run)\n"
  local st="$HOME/.claude/settings.json"
  if grep -q "twin-session" "$st" 2>/dev/null; then printf "$ok capture hooks wired in settings.json\n"; else printf "$warn SessionStart/End hooks not in settings.json\n"; fi

  if [ "$(uname)" = "Darwin" ]; then
    echo "Life-OS (macOS)"
    command -v swift >/dev/null 2>&1 && printf "$ok swift (calendar/reminders reader)\n" || printf "$warn swift missing (no EventKit calendar/reminders)\n"
    if swift "$SELF/twin-rem.swift" list >/dev/null 2>&1; then printf "$ok Reminders access granted\n"; else printf "$warn Reminders access denied (System Settings > Privacy > Reminders)\n"; fi
    if swift "$SELF/twin-cal.swift" 1 >/dev/null 2>&1; then printf "$ok Calendar access granted\n"; else printf "$warn Calendar access denied — grant your terminal app in System Settings > Privacy > Calendars\n"; fi
  fi

  echo "Optional"
  command -v defuddle >/dev/null 2>&1 && printf "$ok defuddle (twin clip)\n" || printf "$warn defuddle missing (twin clip; npm i -g defuddle)\n"
  command -v qmd >/dev/null 2>&1 && printf "$ok qmd (semantic search)\n" || printf "$warn qmd not installed (search falls back to grep)\n"

  echo
  printf "Pending: %s inbox, %s chats unprocessed\n" \
    "$(find "$INBOX" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')" \
    "$(find "$RAW/chats" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
}

cmd_app() { # launch the local web UI (the Vite dev server doubles as the API)
  local appdir="$TWIN_DIR/app"
  [ -d "$appdir" ] || die "no app/ in $TWIN_DIR (re-run install.sh to add the web app)"
  command -v npm >/dev/null 2>&1 || die "twin app needs npm (install Node.js)"
  [ -d "$appdir/node_modules" ] || ( cd "$appdir" && echo "twin: installing app deps (first run)..." && npm install )
  echo "twin: starting web app at http://localhost:5179 (Ctrl-C to stop)"
  ( cd "$appdir" && exec npm run dev )
}

cmd_bar() { # menu bar app (macOS): build / manage TwinBar.app, a login-agent companion
  [ "$(uname)" = "Darwin" ] || die "twin bar is macOS-only"
  local label="com.twin.bar" uid; uid="$(id -u)"
  local plist="$HOME/Library/LaunchAgents/$label.plist"
  case "${1:-status}" in
    build|rebuild|install)
      [ -f "$SELF/build-twin-bar.sh" ] || die "missing $SELF/build-twin-bar.sh (re-run install.sh)"
      command -v swiftc >/dev/null 2>&1 || die "twin bar needs swift (Xcode command line tools)"
      TWIN_DIR="$TWIN_DIR" bash "$SELF/build-twin-bar.sh";;
    restart) launchctl kickstart -k "gui/$uid/$label" && echo "twin bar restarted";;
    stop)
      launchctl bootout "gui/$uid/$label" 2>/dev/null || true
      pkill -f "TwinBar.app/Contents/MacOS/TwinBar" 2>/dev/null || true
      echo "twin bar stopped (won't relaunch until 'twin bar build')";;
    start|load)
      [ -f "$plist" ] || die "not installed — run 'twin bar build'"
      launchctl bootstrap "gui/$uid" "$plist" 2>/dev/null || launchctl kickstart -k "gui/$uid/$label"
      echo "twin bar started";;
    status|*)
      if pgrep -f "TwinBar.app/Contents/MacOS/TwinBar" >/dev/null; then echo "twin bar: running (menu bar)"
      elif [ -d "$SELF/TwinBar.app" ]; then echo "twin bar: built, not running ('twin bar start')"
      else echo "twin bar: not built ('twin bar build')"; fi;;
  esac
}

cmd_status() {
  echo "twin @ $TWIN_DIR"
  echo "  inbox unprocessed : $(find "$INBOX" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  echo "  chats unprocessed : $(find "$RAW/chats" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  echo "  wiki pages        : $(find "$WIKI" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  echo "  tracked projects  : $(python3 -c "import json;d=json.load(open('$REGISTRY'));print(sum(1 for v in d.values() if (v.get('status') if isinstance(v,dict) else v)=='tracked'))" 2>/dev/null || echo 0)"
  echo "  last log entries  :"
  grep "^## \[" "$LOG" 2>/dev/null | tail -3 | sed 's/^/    /' || true
}

cmd_health() { # Apple Health ingest/import/status (deterministic Python, no LLM)
  local py="$SELF/twin-health.py"
  [ -f "$py" ] || die "missing $py"
  case "${1:-status}" in
    ingest) logline "health ingest"; TWIN_DIR="$TWIN_DIR" python3 "$py" ingest;;
    import) shift; [ -n "${1:-}" ] || die "usage: twin health import <export.zip>"
            logline "health import $1"; TWIN_DIR="$TWIN_DIR" python3 "$py" import "$1";;
    status) TWIN_DIR="$TWIN_DIR" python3 "$py" status;;
    coach)  TWIN_DIR="$TWIN_DIR" python3 "$py" coach;;
    *) die "usage: twin health [ingest|import <zip>|status|coach]";;
  esac
}

usage() {
  cat <<'EOF'
twin - your second brain (system: twin, instance: <your vault>)

  twin onboard                     guided first run: setup + a live capture->ingest->ask demo
  twin capture "text"              quick-capture a thought to the inbox
  twin capture --file PATH         capture a file's contents
  echo x | twin capture --stdin    capture from a pipe
      [--source LABEL] [--project NAME]
  twin ingest [--all|PATH]         compile inbox sources into the wiki (Claude)
  twin ask "question"              query the wiki with citations (Claude)
  twin clip URL                    fetch a web page as clean markdown (defuddle)
  twin search "query"              keyword/semantic search the wiki
  twin lint                        deep health-check + reconcile + auto-clean (smart model)
  twin tidy                        cheap mechanical clean + sort into MOCs (Haiku)
  twin research [N]                fill ~N web-research gaps (default 3, soft target)
  twin scout [--deep|--daily]      proactive web discovery -> 'Worth your time' findings
  twin remind "text" [--due STR]   create an Apple Reminder (macOS)
  twin agenda                      briefing: Google Calendar + Reminders + priorities -> generated/
  twin morning                     daily 08:00 job: briefing + triage + scout peek + sync
  twin chat TRANSCRIPT [CWD]       capture a session transcript (hook)
  twin track [PATH]                mark a project as tracked in the brain
  twin private [PATH]              mark a project as private (never captured)
  twin check [PATH]                print tracked|private|unknown for a path
  twin projects                    show the project registry
  twin sync [-m MSG]               secret-scan, commit, push to your git remote
  twin nightly                     ingest + (conditional) tidy + sync  [cheap, scheduled]
  twin weekly                      ingest + lint + research + scout + tidy + sync  [deep, scheduled]
  twin doctor                      health check: deps, permissions, schedule, sync
  twin health [ingest|import ZIP|status|coach]  ingest Apple Health export -> wiki (deterministic)
  twin app                         launch the local web UI (http://localhost:5179)
  twin bar [build|restart|stop]    macOS menu bar app (quick capture, voice notes, ask)
  twin status                      show brain stats
EOF
}

main() {
  local cmd="${1:-status}"; shift || true
  case "$cmd" in
    capture)  cmd_capture "$@";;
    ingest)   cmd_ingest "$@";;
    ask)      cmd_ask "$@";;
    clip)     cmd_clip "$@";;
    search)   cmd_search "$@";;
    lint)     cmd_lint "$@";;
    tidy)     cmd_tidy "$@";;
    research) cmd_research "$@";;
    scout)    cmd_scout "$@";;
    remind)   cmd_remind "$@";;
    calendar)  cmd_calendar "$@";;
    reminders) cmd_reminders "$@";;
    agenda)    cmd_agenda "$@";;
    morning)   cmd_morning "$@";;
    chat)     cmd_chat "$@";;
    track)    cmd_track "$@";;
    private)  cmd_private "$@";;
    check)    cmd_check "$@";;
    projects) cmd_projects "$@";;
    sync)     cmd_sync "$@";;
    nightly)  cmd_nightly "$@";;
    weekly)   cmd_weekly "$@";;
    onboard)  cmd_onboard "$@";;
    doctor)   cmd_doctor "$@";;
    health)   cmd_health "$@";;
    app)      cmd_app "$@";;
    bar)      cmd_bar "$@";;
    status)   cmd_status "$@";;
    help|-h|--help) usage;;
    *) usage; die "unknown command: $cmd";;
  esac
}
main "$@"

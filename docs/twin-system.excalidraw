    {
      "type": "text",
      "id": "clitext",
      "x": 80,
      "y": 544,
      "width": 340,
      "height": 125,
      "text": "$ twin capture \"idea\"   # \u2192 inbox\n$ twin clip <url>       # web \u2192 md\n$ twin ingest           # build wiki\n$ twin ask \"...\"         # cited answer\n$ twin lint             # cleanup\n$ twin sync             # \u2192 GitHub",
      "originalText": "$ twin capture \"idea\"   # \u2192 inbox\n$ twin clip <url>       # web \u2192 md\n$ twin ingest           # build wiki\n$ twin ask \"...\"         # cited answer\n$ twin lint             # cleanup\n$ twin sync             # \u2192 GitHub",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
